# ============================================
# Chat Expert Instance - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================

# ====================
# 数据库配置（必填）
# ====================
# 也可以直接配置在 config/database.json 中
DB_HOST=localhost
DB_PORT=3306
DB_NAME=touwaka_mate
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ====================
# 服务器配置
# ====================
# API 服务器端口（默认 3000）
PORT=3000
# 前端 URL（用于 CORS，默认 http://localhost:5173）
FRONTEND_URL=http://localhost:5173

# ====================
# 数据目录配置
# ====================
# 数据目录路径（默认 ./data）
# 用于存放技能、工作文件等数据（子目录：skills/, work/, kb-images/）
DATA_BASE_PATH=./data
# 工作空间根目录（默认 ./data/work）
WORKSPACE_ROOT=./data/work
# 上传目录（可选）
# UPLOAD_DIR=./data/uploads
# 知识库图片存储目录（默认 ./data/kb-images）
KB_IMAGES_ROOT=./data/kb-images

# ====================
# JWT 配置（生产环境必填！）
# ====================
# ⚠️ 如果不设置，将使用默认值，存在安全风险
# 建议使用 32 位以上的随机字符串
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key

# ====================
# 内部 API 配置
# ====================
# 内部 API 密钥（用于服务间通信）
INTERNAL_API_KEY=
INTERNAL_API_SECRET=internal-api-secret
# 内部 API 基础地址（默认 http://localhost:3000）
INTERNAL_API_BASE=http://localhost:3000

# ====================
# LLM Provider 配置
# ====================
# OpenAI API Key
OPENAI_API_KEY=
# DeepSeek API Key
DEEPSEEK_API_KEY=

# ====================
# Embedding 配置
# ====================
# Embedding API 配置（可选，用于知识库向量化）
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ====================
# Python 配置
# ====================
# Python 可执行文件路径（默认 python3）
PYTHON_PATH=python3

# ====================
# 技能相关配置
# ====================
# Wiki.js 集成（可选）
WIKIJS_URL=
WIKIJS_TOKEN=
# SearXNG 搜索引擎（可选）
SEARXNG_URL=http://localhost:8080
# Unifuncs API（可选）
UNIFUNCS_API_KEY=
# 技能执行超时（毫秒，默认 30000）
VM_TIMEOUT=30000
# Python 执行超时（毫秒，默认 300000）
PYTHON_TIMEOUT=300000
# 常驻技能超时（毫秒，默认 300000）
TIMEOUT_RESIDENT_SKILL=300000

# ====================
# 沙箱配置（Windows）
# ====================
# Sandboxie Plus 安装路径
SANDBOXIE_PATH=C:\Program Files\Sandboxie-Plus\Start.exe
SANDBOXIE_CTRL=C:\Program Files\Sandboxie-Plus\SbieCtrl.exe
# 沙箱监控日志目录
SANDBOX_MONITOR_DIR=./logs/sandbox

# ====================
# Hugging Face 配置
# ====================
# HF 镜像地址（国内可使用 https://hf-mirror.com）
HF_ENDPOINT=https://hf-mirror.com

# ====================
# 日志配置
# ====================
# 日志级别（默认 info）
# debug, info, warn, error
LOG_LEVEL=info
